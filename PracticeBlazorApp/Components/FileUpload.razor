<EditForm Model="fileUploadModel">
    <DataAnnotationsValidator />

    @if (!ParsingSession.IsLoading) {
        <div class="w-100 display-flex flex-column justify-content-center align-items-center align-content-center">
            <InputFile OnChange="UploadFileAndParse" class="form-control form-control-lg"/>

            <p>or...</p>

            <button type="button" class="btn btn-primary" onclick="RunDemo">Show Me a Demo</button>
        </div>
    }

    @if (ParsingSession.IsLoading) {
        <div class="w-100 text-center mt-3">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
</EditForm>