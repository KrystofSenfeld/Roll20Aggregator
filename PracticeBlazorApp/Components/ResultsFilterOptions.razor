<form class="vh-100 py-3 px-2">
    <div class="h-100 d-flex flex-column">
        <div class="w-100 mb-3">
            <h5>Select Die</h5>
            <div class="col">
                <select class="form-select" @onchange="DieSelected">
                    @foreach (var dieType in ParsingSession.ChatLog.AllDieTypes) {
                        <option value="@dieType">@dieType</option>
                    }
                </select>
            </div>
        </div>

        <div><h5>Select Characters</h5></div>

        <div class="list-group list-group-flush overflow-auto flex-grow-1">
            @foreach (var character in ParsingSession.ChatLog.AllCharacters) {
                <button type="button" class="list-group-item list-group-item-@GetColorClass(character) list-group-item-action"
                    @onclick="() => ToggleCharacterSelected(character)">
                    <div class="d-flex justify-content-between">
                        <div>
                            @character
                        </div>
                        <div><i class="fa-solid fa-fw fa-@GetIcon(character)"></i></div>
                    </div>
                </button>
            }
        </div>

        <div class="mt-3">
            <a href="/" class="btn btn-outline-secondary">Back</a>
        </div>
    </div>
</form>